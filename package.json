{
  "name": "cucumber-playwright-scaffold",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "npm run test:cucumber",
    "test:cucumber": "cucumber-js",
    "test:headed": "cross-env HEADLESS=false npm run test:cucumber",
    "test:headless": "cross-env HEADLESS=true npm run test:cucumber",
    "explore": "node ./node_modules/@playwright/mcp/explore.js",
    "playwright:install": "playwright install",
    "generate:allure": "npx allure generate ./allure-results -o ./allure-report",
    "open:allure": "npx allure open ./allure-report",
    "allure:serve": "allure serve allure-results",
    "runtestwithallure": "npm run test:cucumber && npm run generate:allure && npm run open:allure"

  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@types/node": "^25.9.3",
    "cross-env": "^7.0.3",
    "playwright": "*",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@playwright/cli": "^0.1.14",
    "@playwright/mcp": "^0.0.76",
    "@playwright/test": "^1.60.0",
    "allure-commandline": "^2.42.1",
    "allure-cucumberjs": "^3.10.0",
    "allure-playwright": "^3.10.0",
    "multiple-cucumber-html-reporter": "^4.0.0",
    "playwright-cli": "^0.262.0"
  }
}
